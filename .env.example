# =============================================================================
# CONTACT FORM — pick ONE approach for production
# =============================================================================
#
# A) FREE static hosting (Hostinger FTP, Netlify static, GitHub Pages, etc.)
#    No Node server needed. Sign up at https://web3forms.com (free) with your
#    clinic email, copy the Access Key, put it here, then run: npm run build
#    One line, no spaces around =, no quotes. If Web3Forms says "Invalid Access Key"
#    on the live site: copy the key again from the dashboard, rebuild, re-upload dist.
#
# VITE_WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

#
# B) Local dev / your own Node API (npm run dev, or VPS + nginx + /api proxy)
#    Leave VITE_WEB3FORMS_ACCESS_KEY empty and use:
#
# GMAIL + Express (server/index.js) — also used if you deploy api/contact on Vercel
PORT=5000
ADMIN_EMAIL=ayushmanphysiocare@gmail.com
GMAIL_USER=ayushmanphysiocare@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
# CORS_ORIGINS=https://ayushmanphysiocare.com,https://www.ayushmanphysiocare.com
#
# Optional: if the API is on another URL, set full endpoint and rebuild:
# VITE_CONTACT_API_URL=https://your-project.vercel.app/api/contact
